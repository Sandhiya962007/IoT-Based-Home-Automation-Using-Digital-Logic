#define BLYNK_TEMPLATE_ID "YOUR_TEMPLATE_ID"
#define BLYNK_TEMPLATE_NAME "HomeAutomation"
#define BLYNK_AUTH_TOKEN "YOUR_AUTH_TOKEN"

#include <WiFi.h>
#include <WiFiClient.h>
#include <BlynkSimpleEsp32.h>
#include <DHT.h>

// WiFi Credentials
char ssid[] = "YOUR_WIFI_NAME";
char pass[] = "YOUR_WIFI_PASSWORD";

// Ultrasonic Sensor
#define TRIG_PIN 5
#define ECHO_PIN 18

// Presence Detection Output
#define PRESENCE_PIN 19

// D Flip-Flop Output
#define OCCUPANCY_PIN 21

// LDR Sensor
#define LDR_PIN 34

// LED
#define LIGHT_PIN 26

// DHT11
#define DHTPIN 4
#define DHTTYPE DHT11

DHT dht(DHTPIN, DHTTYPE);

BlynkTimer timer;

// --------------------------------

void sendSensorData()
{
  // Ultrasonic

  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);

  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);

  digitalWrite(TRIG_PIN, LOW);

  long duration = pulseIn(ECHO_PIN, HIGH, 30000);

  float distance = duration * 0.034 / 2;

  // Presence Detection

  if (distance < 200)
    digitalWrite(PRESENCE_PIN, HIGH);
  else
    digitalWrite(PRESENCE_PIN, LOW);

  // Occupancy

  bool occupancy = digitalRead(OCCUPANCY_PIN);

  // LDR

  int ldrValue = analogRead(LDR_PIN);

  bool dark = (ldrValue > 2500);

  // Light Control

  if (occupancy && dark)
    digitalWrite(LIGHT_PIN, HIGH);
  else
    digitalWrite(LIGHT_PIN, LOW);

  // Temperature

  float temp = dht.readTemperature();

  // Send to Blynk

  Blynk.virtualWrite(V0, distance);
  Blynk.virtualWrite(V1, occupancy);
  Blynk.virtualWrite(V2, ldrValue);
  Blynk.virtualWrite(V3, temp);
  Blynk.virtualWrite(V4, digitalRead(LIGHT_PIN));

  // Serial Monitor

  Serial.println("--------------------");

  Serial.print("Distance: ");
  Serial.print(distance);
  Serial.println(" cm");

  Serial.print("Occupancy: ");
  Serial.println(occupancy ? "HIGH" : "LOW");

  Serial.print("LDR: ");
  Serial.println(ldrValue);

  Serial.print("Temperature: ");
  Serial.print(temp);
  Serial.println(" C");

  Serial.print("LED Status: ");
  Serial.println(digitalRead(LIGHT_PIN) ? "ON" : "OFF");
}

// --------------------------------

void setup()
{
  Serial.begin(115200);

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  pinMode(PRESENCE_PIN, OUTPUT);

  pinMode(OCCUPANCY_PIN, INPUT);

  pinMode(LIGHT_PIN, OUTPUT);

  digitalWrite(LIGHT_PIN, LOW);

  dht.begin();

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  timer.setInterval(1000L, sendSensorData);
}

// --------------------------------

void loop()
{
  Blynk.run();
  timer.run();
}
